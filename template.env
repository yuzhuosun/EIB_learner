# Provider options:
# - openai_compatible: existing remote gateway format
# - ollama: local ollama /api/chat format
LLM_PROVIDER='openai_compatible'

# openai_compatible example:
# BASE_URL='https://your-gateway/chat'
# API_KEY='your-key'

# ollama local example:
# LLM_PROVIDER='ollama'
# BASE_URL='http://127.0.0.1:11434/api/chat'
# API_KEY=''  # not required
BASE_URL=''
API_KEY=''
